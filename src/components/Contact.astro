---
interface Props {
  isMini?: boolean;
}

const { isMini = false } = Astro.props;

const contacts = [
  {
    label: "Email",
    value: "ev.cureton@gmail.com",
    href: "mailto:ev.cureton@gmail.com",
  },
  {
    label: "LinkedIn",
    value: "linkedin.com/in/evan-cureton",
    href: "https://linkedin.com/in/evan-cureton",
  },
  {
    label: "GitHub",
    value: "github.com/evan-cure",
    href: "https://github.com/evan-cure",
  },
];
---

<div class={`content-section contact ${isMini ? "mini" : "full"}`}>
  <h2 class="section-heading">
    Contact
    {isMini ? <a href="/contact">↝</a> : <a href="/">↜</a>}
  </h2>
  <p>Feel free to reach out.</p>
  <div class="contact-list">
    {
      contacts.map((contact) => (
        <a
          href={contact.href}
          target="_blank"
          rel="noreferrer"
          class="contact-link"
        >
          <div class="contact-item">
            <h3>{contact.label}</h3>
            <p>{contact.value}</p>
          </div>
        </a>
      ))
    }
  </div>
</div>

<style>
  .content-section {
    font-family: "Lexend Giga", sans-serif;
  }

  .content-section.mini {
    font-size: 0.8em;
    max-height: 400px;
  }

  .content-section.full {
    padding: 40px;
    min-height: 100vh;
    color: white;
  }

  .content-section h2 {
    margin: 0 0 20px 0;
    color: white;
  }

  .section-heading a {
    color: inherit;
    text-decoration: none;
  }

  .section-heading a:visited {
    color: inherit;
  }

  .content-section p {
    line-height: 1.6;
    margin: 0 0 30px 0;
    color: white;
  }

  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .contact-link {
    text-decoration: none;
    color: inherit;
    transition:
      transform 0.2s,
      opacity 0.2s;
  }

  .contact-link:hover {
    transform: translateX(4px);
    opacity: 0.8;
  }

  .contact-link:hover .contact-item {
    background-color: rgba(255, 255, 255, 0.05);
  }

  .contact-item {
    padding: 15px;
    border-left: 2px solid #4a9d6f;
    transition: background-color 0.2s;
  }

  .contact-item h3 {
    margin: 0 0 5px 0;
    font-size: 1.1em;
    color: white;
  }

  .contact-item p {
    margin: 0;
    font-size: 0.9em;
    opacity: 0.8;
  }
</style>
