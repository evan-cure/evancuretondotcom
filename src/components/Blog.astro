---
import { getCollection } from "astro:content";

interface Props {
  isMini?: boolean;
}

const { isMini = false } = Astro.props;

const posts = await getCollection("blog");
const sortedPosts = posts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

{!isMini && <canvas id="boids-canvas" />}
<div class={`content-section blog ${isMini ? "mini" : "full"}`}>
  <h2 class="section-heading">
    Blog
    {isMini ? <a href="/blog">↝</a> : <a href="/">↜</a>}
  </h2>
  <div class="blog-list">
    {
      sortedPosts.length > 0 ? (
        sortedPosts.map((post) => (
          <a
            href={`/blog/${post.id.replace(/\.md$/, "")}`}
            class="blog-post-link"
          >
            <article class="blog-post">
              <h3>{post.data.title}</h3>
              <p class="date">
                {post.data.date.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </p>
              {post.data.description && (
                <p class="description">{post.data.description}</p>
              )}
            </article>
          </a>
        ))
      ) : (
        <article class="blog-post">
          <h3>No posts yet</h3>
          <p class="date">Coming soon...</p>
        </article>
      )
    }
  </div>
</div>

<style>
  #boids-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
  }

  .content-section {
    font-family: "Lexend Giga", sans-serif;
    position: relative;
    z-index: 1;
  }

  .blog-post-link {
    text-decoration: none;
    color: inherit;
    display: block;
    transition:
      transform 0.2s,
      opacity 0.2s;
  }

  .blog-post-link:hover {
    transform: translateX(4px);
    opacity: 0.8;
  }

  .blog-post-link:hover .blog-post {
    background-color: #1a1a1a;
  }

  .blog-post {
    padding: 12px;
    border-radius: 8px;
    transition: background-color 0.2s;
  }

  .content-section.mini {
    font-size: 0.8em;
    max-height: 400px;
  }

  .content-section.full {
    padding: 40px;
    min-height: 100vh;
  }

  .content-section h2 {
    margin: 0 0 20px 0;
  }

  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .blog-post {
    padding: 15px;
    border-left: 2px solid #4a9d6f;
  }

  .blog-post h3 {
    margin: 0 0 5px 0;
    font-size: 1.1em;
  }

  .blog-post .date {
    margin: 0;
    font-size: 0.85em;
    opacity: 0.7;
  }

  .blog-post .description {
    margin: 8px 0 0 0;
    font-size: 0.9em;
    opacity: 0.85;
    line-height: 1.5;
  }

  .section-heading a {
    color: inherit;
    text-decoration: none;
  }

  .section-heading a:visited {
    color: inherit;
  }
</style>
