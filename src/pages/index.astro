---
import Projects from "../components/Projects.astro";
import Pictures from "../components/Pictures.astro";
import Blog from "../components/Blog.astro";
import About from "../components/About.astro";
import Contact from "../components/Contact.astro";
import "../styles/index.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="images/Star 1.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lexend+Giga:wght@100..900&display=swap"
      rel="stylesheet"
    />
    <title>Evan Cureton</title>
  </head>
  <body>
    <main>
      <div class="hero">
        <div id="projects-popup" class="popup">
          <Projects isMini={true} />
        </div>
        <div id="pictures-popup" class="popup">
          <Pictures isMini={true} />
        </div>
        <div id="blog-popup" class="popup">
          <Blog isMini={true} />
        </div>
        <div id="about-popup" class="popup">
          <About isMini={true} />
        </div>
        <div id="contact-popup" class="popup">
          <Contact isMini={true} />
        </div>
        <canvas id="boids-canvas"></canvas>
        <div class="accent-box">
          <nav class="accent-nav">
            <div class="nav-item-wrapper">
              <button class="nav-btn" data-popup="projects">Projects</button>
              <img
                class="nav-indicator"
                src="/images/star-2.svg"
                alt="active"
              />
            </div>
            <div class="nav-item-wrapper">
              <button class="nav-btn" data-popup="pictures">Pictures</button>
              <img
                class="nav-indicator"
                src="/images/star-2.svg"
                alt="active"
              />
            </div>
            <div class="nav-item-wrapper">
              <button class="nav-btn" data-popup="blog">Blog</button>
              <img
                class="nav-indicator"
                src="/images/star-2.svg"
                alt="active"
              />
            </div>
            <div class="nav-item-wrapper">
              <button class="nav-btn" data-popup="about">About</button>
              <img
                class="nav-indicator"
                src="/images/star-2.svg"
                alt="active"
              />
            </div>
            <div class="nav-item-wrapper">
              <button class="nav-btn" data-popup="contact">Contact</button>
              <img
                class="nav-indicator"
                src="/images/star-2.svg"
                alt="active"
              />
            </div>
          </nav>
        </div>
        <div class="domain-text">evancureton.com</div>
      </div>
    </main>
  </body>
  <script src="../scripts/boids.ts"></script>
  <script src="../scripts/nav.ts"></script>
</html>
