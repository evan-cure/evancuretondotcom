  <script src="../boids.ts"></script>
  <script>
    const navBtns = document.querySelectorAll(".nav-btn");
    const toggledPopup = {}; // Track which popup is toggled (only one)

    navBtns.forEach((btn) => {
      const popupId = btn.dataset.popup;

      const popup = document.getElementById(`${popupId}-popup`);
      const indicator = btn.parentElement.querySelector(".nav-indicator");
      const navItemWrapper = btn.parentElement;

      btn.addEventListener("click", () => {
        // If another popup is toggled, close it first
        Object.keys(toggledPopup).forEach((otherId) => {
          if (otherId !== popupId) {
            toggledPopup[otherId] = false;
            const otherPopup = document.getElementById(`${otherId}-popup`);
            const otherBtn = document.querySelector(
              `[data-popup="${otherId}"]`,
            );
            const otherIndicator =
              otherBtn.parentElement.querySelector(".nav-indicator");
            otherPopup.classList.remove("active");
            otherIndicator.classList.remove("active");
          }
        });

        // Toggle this popup
        if (toggledPopup[popupId]) {
          toggledPopup[popupId] = false;
          popup.classList.remove("active");
          indicator.classList.remove("active");
        } else {
          toggledPopup[popupId] = true;
          popup.classList.add("active");
          indicator.classList.add("active");
        }
      });

      btn.addEventListener("mouseenter", () => {
        // Only show hover preview if no popup is currently toggled
        const isAnyToggled = Object.values(toggledPopup).some((val) => val);
        if (!isAnyToggled) {
          popup.classList.add("active");
        }
      });

      // Hide popup when mouse leaves the nav item (much tighter hitbox)
      navItemWrapper.addEventListener("mouseleave", () => {
        if (!toggledPopup[popupId]) {
          popup.classList.remove("active");
        }
      });
    });
  </script>
